   "source": [
    "import heapq\n",
    "\n",
    "class Solution:\n",
    "    def findKthLargest(self, nums: List[int], k: int) -> int:\n",
    "\n",
    "        heap = []\n",
    "\n",
    "        for num in nums:\n",
    "\n",
    "            heapq.heappush(heap, num)\n",
    "\n",
    "            if len(heap) > k:\n",
    "                heapq.heappop(heap)\n",
    "        return heap[0]\n"
   ]
  },
